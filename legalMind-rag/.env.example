# LLM Provider — pick one: "openai" or "gemini"
LLM_PROVIDER=gemini

# Required for the selected provider
# OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your-gemini-key

# App
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# OpenAI models (used when LLM_PROVIDER=openai)
EMBEDDING_MODEL=text-embedding-ada-002
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Gemini models (used when LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_VISION_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=5
SIMILARITY_THRESHOLD=0.70
RERANKER_ENABLED=false

# Vector Store (choose one backend)
VECTOR_STORE_BACKEND=chroma
CHROMA_PATH=./data/vectorstore
CHROMA_COLLECTION_NAME=legalMind_docs

# Pinecone (optional, set VECTOR_STORE_BACKEND=pinecone to use)
# PINECONE_API_KEY=...
# PINECONE_INDEX_NAME=legalMind
# PINECONE_ENVIRONMENT=us-east-1-aws

# PostgreSQL (only used if/when you wire it in)
POSTGRES_URL=postgresql+asyncpg://rag:rag@localhost:5432/legalMind

# Redis (cache is optional — set CACHE_ENABLED=false to skip)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
CACHE_ENABLED=false

# Security
SECRET_KEY=change-me-to-a-very-long-random-string-in-production
JWT_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=["http://localhost:3000"]

# Observability
PROMETHEUS_ENABLED=true
# OTEL_ENDPOINT=http://otel-collector:4317
