# LLM Provider (gemini | openai)
LLM_PROVIDER=gemini

# Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# App
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Vector store
VECTOR_STORE_BACKEND=chroma
CHROMA_PATH=./data/vectorstore
CHROMA_COLLECTION_NAME=support_kb

# BM25 keyword index
BM25_INDEX_PATH=./data/bm25/index.pkl

# Retrieval — hybrid search
DENSE_TOP_K=20
SPARSE_TOP_K=20
HYBRID_TOP_K=20
FINAL_TOP_K=5
RRF_K=60

# Reranking
RERANKER_ENABLED=true
RERANKER_BACKEND=cross_encoder
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Query rewriting
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_VARIANTS=3
HYDE_ENABLED=true

# Chunking
CHUNK_SIZE=480
CHUNK_OVERLAP=64
SEMANTIC_CHUNKING=true

# Security
SECRET_KEY=local-dev-only-change-me-local-dev-only-change-me
ALLOWED_ORIGINS=["http://localhost:3000"]

# Observability
PROMETHEUS_ENABLED=true
